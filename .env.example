# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://pyraworkspacedb.pyramedia.cloud
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App
NEXT_PUBLIC_APP_URL=https://workspace.pyramedia.cloud
NEXT_PUBLIC_APP_NAME=Pyra Workspace
NODE_ENV=production

# Storage
NEXT_PUBLIC_STORAGE_BUCKET=pyraai-workspace

# Stripe (can also be configured via Settings page in dashboard)
STRIPE_SECRET_KEY=sk_live_or_sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
