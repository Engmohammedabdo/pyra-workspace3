    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst data = body.data || {};\nconst key = data.key || {};\nconst msg = data.message || {};\nconst remoteJid = key.remoteJid || '';\nconst pushName = data.pushName || '';\nconst messageType = data.messageType || 'conversation';\nlet userMessage = '';\nlet mediaKey = '';\nlet fileName = '';\nswitch(messageType) {\n  case 'conversation': userMessage = msg.conversation || ''; break;\n  case 'extendedTextMessage': userMessage = msg.extendedTextMessage?.text || ''; break;\n  case 'audioMessage': userMessage = '[رسالة صوتية]'; mediaKey = key.id || ''; break;\n  case 'imageMessage': userMessage = '[صورة' + (msg.imageMessage?.caption ? ': ' + msg.imageMessage.caption : '') + ']'; mediaKey = key.id || ''; break;\n  case 'documentMessage': fileName = msg.documentMessage?.fileName || 'document'; userMessage = '[مستند: ' + fileName + ']'; mediaKey = key.id || ''; break;\n}\nreturn [{json: {remoteJid, pushName, messageType, userMessage, mediaKey, fileName, messageId: key.id || '', instanceName: body.instance || 'test1'}}];"
      },
