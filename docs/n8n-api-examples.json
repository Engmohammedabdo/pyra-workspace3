{
  "_info": {
    "title": "Pyra Workspace - External API Reference for n8n AI Agent",
    "version": "3.0.0",
    "base_url": "https://workspace.pyramedia.cloud",
    "auth_header": "X-API-Key",
    "auth_note": "Create API keys from: Dashboard → Settings → External API Keys section",
    "important_rules": [
      "The AI agent MUST fetch categories from GET /api/external/expenses/categories before creating expenses",
      "The AI agent MUST use only existing category IDs — never invent or guess categories",
      "When processing a subscription invoice, ALWAYS search subscriptions first before creating a new one",
      "Use category_id (not category name) when creating expenses for accuracy",
      "The search in GET /api/external/subscriptions is fuzzy (partial match, case-insensitive)"
    ]
  },

  "endpoints": {

    "1_verify_api_key": {
      "description": "Verify API key is valid and check permissions",
      "method": "GET",
      "url": "{{base_url}}/api/external/status",
      "headers": { "X-API-Key": "{{api_key}}" },
      "response_example": {
        "data": {
          "status": "ok",
          "key_name": "n8n Integration",
          "permissions": ["expenses:create", "expenses:read", "subscriptions:read", "subscriptions:create", "invoices:create", "invoices:read", "invoices:send", "alerts:read"]
        }
      }
    },

    "2_get_expense_categories": {
      "description": "MUST be called first — Get all valid expense categories. The AI agent must ONLY use these categories. Never invent new ones.",
      "permission_required": "expenses:read",
      "method": "GET",
      "url": "{{base_url}}/api/external/expenses/categories",
      "headers": { "X-API-Key": "{{api_key}}" },
      "response_example": {
        "data": [
          { "id": "ec_abc123", "name": "Subscriptions", "name_ar": "اشتراكات" },
          { "id": "ec_def456", "name": "Food & Beverages", "name_ar": "طعام ومشروبات" },
          { "id": "ec_ghi789", "name": "Transportation", "name_ar": "مواصلات" },
          { "id": "ec_jkl012", "name": "Office Supplies", "name_ar": "مستلزمات مكتبية" },
          { "id": "ec_mno345", "name": "Marketing", "name_ar": "تسويق" },
          { "id": "ec_pqr678", "name": "Software", "name_ar": "برامج" },
          { "id": "ec_stu901", "name": "Hosting", "name_ar": "استضافة" }
        ],
        "error": null
      },
      "usage_note": "Cache this response at the start of each workflow. Use the id field as category_id when creating expenses."
    },

    "3_search_subscriptions": {
      "description": "Search existing subscriptions by name/provider (fuzzy, case-insensitive, partial match). Use this to check if a subscription already exists before creating an expense.",
      "permission_required": "subscriptions:read",
      "method": "GET",
      "url": "{{base_url}}/api/external/subscriptions?search={{keyword}}",
      "headers": { "X-API-Key": "{{api_key}}" },
      "query_params": {
        "search": "(optional) fuzzy search on name + provider — e.g., 'eleven' matches 'ElevenLabs', 'Eleven Labs', etc.",
        "status": "(optional) filter by: active, paused, cancelled",
        "page": "(optional) default: 1",
        "pageSize": "(optional) default: 20, max: 100"
      },
      "examples": [
        "GET /api/external/subscriptions?search=eleven → finds 'ElevenLabs'",
        "GET /api/external/subscriptions?search=adobe → finds 'Adobe Creative Cloud'",
        "GET /api/external/subscriptions?search=figma → finds 'Figma Pro'"
      ],
      "response_example": {
        "data": [
          {
            "id": "sub_abc123",
            "name": "ElevenLabs",
            "provider": "ElevenLabs",
            "cost": 5,
            "currency": "USD",
            "billing_cycle": "monthly",
            "next_renewal_date": "2026-03-15",
            "category": "أدوات",
            "status": "active",
            "auto_renew": true
          }
        ],
        "meta": { "total": 1, "page": 1, "pageSize": 20 },
        "error": null
      }
    },

    "4_create_subscription": {
      "description": "Create a new subscription record. Use only when the subscription does NOT exist yet.",
      "permission_required": "subscriptions:create",
      "method": "POST",
      "url": "{{base_url}}/api/external/subscriptions",
      "headers": {
        "Content-Type": "application/json",
        "X-API-Key": "{{api_key}}"
      },
      "body": {
        "name": "ElevenLabs",
        "provider": "ElevenLabs",
        "cost": 5,
        "currency": "USD",
        "billing_cycle": "monthly",
        "next_renewal_date": "2026-04-15",
        "category": "أدوات",
        "notes": "AI voice generation",
        "source": "n8n"
      },
      "body_fields": {
        "name": "(required) subscription name",
        "provider": "(optional) provider/vendor name",
        "cost": "(required) amount per billing cycle — must be > 0",
        "currency": "(optional) default: AED",
        "billing_cycle": "(optional) monthly | quarterly | yearly — default: monthly",
        "next_renewal_date": "(optional) YYYY-MM-DD",
        "category": "(optional) free-text category for the subscription",
        "url": "(optional) subscription URL",
        "notes": "(optional) additional notes",
        "source": "(optional) source identifier — e.g., n8n, telegram"
      },
      "response_example": {
        "data": {
          "id": "sub_abc123",
          "name": "ElevenLabs",
          "provider": "ElevenLabs",
          "cost": 5,
          "currency": "USD",
          "billing_cycle": "monthly",
          "status": "active"
        }
      }
    },

    "5_create_expense": {
      "description": "Create a new expense. Use category_id from GET /categories endpoint. Optionally link to a subscription_id.",
      "permission_required": "expenses:create",
      "method": "POST",
      "url": "{{base_url}}/api/external/expenses",
      "headers": {
        "Content-Type": "application/json",
        "X-API-Key": "{{api_key}}"
      },
      "body": {
        "description": "ElevenLabs — تجديد اشتراك شهري",
        "amount": 5,
        "currency": "USD",
        "category_id": "ec_abc123",
        "subscription_id": "sub_abc123",
        "vendor": "ElevenLabs",
        "expense_date": "2026-02-26",
        "payment_method": "credit_card",
        "notes": "تجديد تلقائي",
        "source": "n8n"
      },
      "body_fields": {
        "description": "(required) expense description",
        "amount": "(required) must be > 0",
        "currency": "(optional) default: AED",
        "category_id": "(recommended) category ID from GET /expenses/categories — takes priority over 'category'",
        "category": "(fallback) category name in Arabic or English — matched against existing categories",
        "subscription_id": "(optional) link this expense to an existing subscription — validated against pyra_subscriptions",
        "vendor": "(optional) vendor name",
        "expense_date": "(optional) YYYY-MM-DD — default: today",
        "payment_method": "(optional) cash | credit_card | bank_transfer | debit_card",
        "notes": "(optional) additional notes",
        "project_id": "(optional) link to a project",
        "source": "(optional) source identifier — e.g., telegram, n8n"
      },
      "response_example": {
        "data": {
          "id": "exp_abc123",
          "description": "ElevenLabs — تجديد اشتراك شهري",
          "amount": 5,
          "currency": "USD",
          "category_id": "ec_abc123",
          "subscription_id": "sub_abc123",
          "vendor": "ElevenLabs",
          "expense_date": "2026-02-26"
        }
      }
    },

    "6_create_expense_minimal": {
      "description": "Create expense with minimum required fields (for simple one-time expenses)",
      "method": "POST",
      "url": "{{base_url}}/api/external/expenses",
      "headers": {
        "Content-Type": "application/json",
        "X-API-Key": "{{api_key}}"
      },
      "body": {
        "description": "غداء فريق العمل",
        "amount": 350,
        "category_id": "ec_def456",
        "source": "telegram"
      }
    },

    "7_list_expenses": {
      "description": "List expenses with optional filters",
      "permission_required": "expenses:read",
      "method": "GET",
      "url": "{{base_url}}/api/external/expenses?from=2026-01-01&to=2026-02-28&page=1&pageSize=20",
      "headers": { "X-API-Key": "{{api_key}}" },
      "query_params": {
        "category_id": "(optional) filter by category ID",
        "vendor": "(optional) partial match on vendor name",
        "project_id": "(optional) filter by project ID",
        "from": "(optional) start date — YYYY-MM-DD",
        "to": "(optional) end date — YYYY-MM-DD",
        "page": "(optional) default: 1",
        "pageSize": "(optional) default: 20, max: 100"
      }
    },

    "8_create_invoice": {
      "description": "Create a new invoice for a client",
      "permission_required": "invoices:create",
      "method": "POST",
      "url": "{{base_url}}/api/external/invoices",
      "headers": {
        "Content-Type": "application/json",
        "X-API-Key": "{{api_key}}"
      },
      "body": {
        "client_name": "شركة إنجازات",
        "items": [
          { "description": "تصميم هوية بصرية", "quantity": 1, "rate": 5000 },
          { "description": "إدارة سوشال ميديا — فبراير", "quantity": 1, "rate": 3000 }
        ],
        "currency": "AED",
        "due_date": "2026-03-26",
        "notes": "فاتورة خدمات فبراير 2026",
        "source": "n8n"
      },
      "body_fields": {
        "client_id": "(optional) client ID if known",
        "client_name": "(optional) client name — auto-searched in database",
        "items": "(required) array of line items",
        "items[].description": "(required) item description",
        "items[].quantity": "(optional) default: 1",
        "items[].rate": "(required) unit price",
        "currency": "(optional) default: AED",
        "due_date": "(optional) YYYY-MM-DD",
        "notes": "(optional)",
        "source": "(optional)"
      }
    },

    "9_list_invoices": {
      "description": "List invoices with optional filters",
      "permission_required": "invoices:read",
      "method": "GET",
      "url": "{{base_url}}/api/external/invoices?status=sent&page=1&pageSize=10",
      "headers": { "X-API-Key": "{{api_key}}" },
      "query_params": {
        "status": "(optional) draft | sent | paid | partially_paid | overdue | cancelled",
        "client_id": "(optional) filter by client ID",
        "page": "(optional) default: 1",
        "pageSize": "(optional) default: 20, max: 100"
      }
    },

    "10_send_invoice": {
      "description": "Send a draft invoice (change status from draft to sent)",
      "permission_required": "invoices:send",
      "method": "POST",
      "url": "{{base_url}}/api/external/invoices/{{invoice_id}}/send",
      "headers": { "X-API-Key": "{{api_key}}" }
    },

    "11_get_alerts": {
      "description": "Get smart financial alerts (overdue invoices, expiring contracts, budget overruns, subscription renewals)",
      "permission_required": "alerts:read",
      "method": "GET",
      "url": "{{base_url}}/api/external/alerts",
      "headers": { "X-API-Key": "{{api_key}}" },
      "response_example": {
        "data": {
          "alerts": [
            {
              "type": "overdue_invoices",
              "severity": "critical",
              "title": "فواتير متأخرة",
              "message": "يوجد 3 فاتورة متأخرة بإجمالي 25000.00"
            },
            {
              "type": "subscription_renewal",
              "severity": "warning",
              "title": "تجديد اشتراك قادم",
              "message": "الاشتراك \"Adobe CC\" سيتجدد في 2026-03-01 بقيمة 250.00 AED"
            }
          ],
          "summary": { "total_count": 5, "critical_count": 1, "warning_count": 3, "info_count": 1 }
        }
      }
    }
  },

  "ai_agent_workflow": {
    "title": "Telegram Invoice Photo → AI Agent → Pyra API",
    "description": "Complete flow for the AI agent to process invoice photos sent via Telegram and create the correct records in Pyra",

    "step_0_init": {
      "description": "On startup, cache categories and use them throughout the session",
      "action": "GET /api/external/expenses/categories",
      "result": "Store the categories array. The AI agent must ONLY use category IDs from this list.",
      "critical_rule": "NEVER create, invent, or guess a category. If no category matches, use null."
    },

    "step_1_receive_photo": {
      "description": "User sends invoice photo via Telegram",
      "action": "AI reads the photo and extracts: vendor_name, amount, currency, date, description, is_recurring (yes/no)"
    },

    "step_2_classify": {
      "description": "AI classifies the invoice type",
      "decision_tree": {
        "is_recurring_or_subscription": {
          "condition": "Is this a subscription/recurring service? (SaaS, hosting, cloud, tools, etc.)",
          "yes": "→ Go to step_3_subscription_flow",
          "no": "→ Go to step_4_regular_expense_flow"
        }
      },
      "subscription_indicators": [
        "Monthly/yearly billing cycle mentioned",
        "Known SaaS providers (Adobe, AWS, Google, Microsoft, Figma, Slack, etc.)",
        "Words like: subscription, renewal, recurring, plan, license, تجديد, اشتراك",
        "Auto-renewal or next billing date mentioned"
      ]
    },

    "step_3_subscription_flow": {
      "description": "Handle subscription invoice",
      "steps": [
        {
          "step": "3a",
          "action": "GET /api/external/subscriptions?search={{vendor_keyword}}",
          "note": "Use a keyword from the vendor name. e.g., for 'Eleven Labs Inc.' use search=eleven. The API does fuzzy partial match.",
          "examples": [
            "vendor: 'ElevenLabs Inc.' → search=eleven",
            "vendor: 'Adobe Systems' → search=adobe",
            "vendor: 'Amazon Web Services' → search=aws OR search=amazon",
            "vendor: 'Google Cloud Platform' → search=google"
          ]
        },
        {
          "step": "3b",
          "condition": "Subscription found?",
          "yes": "Use the subscription_id from the response → Go to step 3d",
          "no": "→ Go to step 3c (create new subscription)"
        },
        {
          "step": "3c",
          "action": "POST /api/external/subscriptions",
          "body": {
            "name": "{{vendor_name}}",
            "provider": "{{vendor_name}}",
            "cost": "{{amount}}",
            "currency": "{{currency}}",
            "billing_cycle": "monthly (or yearly/quarterly based on invoice)",
            "next_renewal_date": "{{calculate from invoice date + billing cycle}}",
            "source": "n8n"
          },
          "result": "Save the returned subscription_id"
        },
        {
          "step": "3d",
          "action": "POST /api/external/expenses",
          "body": {
            "description": "{{vendor_name}} — تجديد اشتراك {{billing_cycle}}",
            "amount": "{{amount}}",
            "currency": "{{currency}}",
            "category_id": "{{id of 'اشتراكات' category from cached categories}}",
            "subscription_id": "{{subscription_id from step 3b or 3c}}",
            "vendor": "{{vendor_name}}",
            "expense_date": "{{invoice_date}}",
            "payment_method": "credit_card",
            "source": "n8n"
          }
        }
      ]
    },

    "step_4_regular_expense_flow": {
      "description": "Handle regular (non-subscription) expense",
      "steps": [
        {
          "step": "4a",
          "action": "Match the expense to the best category from cached categories",
          "rules": [
            "If vendor is restaurant/cafe → use 'طعام ومشروبات' category",
            "If vendor is Uber/Careem/taxi → use 'مواصلات' category",
            "If vendor is office supply store → use 'مستلزمات مكتبية' category",
            "If unsure → set category_id to null (DO NOT guess)",
            "NEVER create a category that doesn't exist in the list"
          ]
        },
        {
          "step": "4b",
          "action": "POST /api/external/expenses",
          "body": {
            "description": "{{description from invoice}}",
            "amount": "{{amount}}",
            "currency": "{{currency}}",
            "category_id": "{{matched category_id or null}}",
            "vendor": "{{vendor_name}}",
            "expense_date": "{{invoice_date}}",
            "payment_method": "{{inferred or null}}",
            "source": "n8n"
          }
        }
      ]
    },

    "step_5_reply": {
      "description": "Send confirmation back to Telegram",
      "template_subscription": "✅ تم تسجيل اشتراك {{vendor}} بمبلغ {{amount}} {{currency}}\n📂 التصنيف: اشتراكات\n🔗 مرتبط باشتراك: {{subscription_name}}",
      "template_expense": "✅ تم تسجيل مصروف {{amount}} {{currency}}\n📝 {{description}}\n📂 التصنيف: {{category_name}}"
    }
  },

  "n8n_workflows": {

    "ai_invoice_processor": {
      "description": "Main AI Agent workflow: Telegram Photo → AI Analysis → Smart Expense/Subscription Creation",
      "flow": "Telegram Trigger (photo) → AI Agent (analyze) → Tool Calls (Pyra API) → Telegram Reply",
      "steps": [
        {
          "step": 1,
          "node": "Telegram Trigger",
          "config": "Listen for photo messages in bot chat"
        },
        {
          "step": 2,
          "node": "AI Agent (OpenAI/Claude)",
          "description": "Analyze the invoice photo and extract data",
          "system_prompt": "You are a financial assistant. Analyze invoice photos and extract: vendor_name, amount, currency, date, description, is_subscription (boolean). Use the Pyra API tools to create the correct records. Follow the ai_agent_workflow steps exactly.",
          "tools": [
            "GET /api/external/expenses/categories",
            "GET /api/external/subscriptions?search=",
            "POST /api/external/subscriptions",
            "POST /api/external/expenses"
          ]
        },
        {
          "step": 3,
          "node": "Telegram Reply",
          "config": "Send confirmation with expense/subscription details"
        }
      ]
    },

    "telegram_expense_bot": {
      "description": "Simple text-based expense bot (no AI, just parsing)",
      "flow": "Telegram Trigger → Parse Message → HTTP Request → Reply",
      "steps": [
        {
          "step": 1,
          "node": "Telegram Trigger",
          "config": "Listen for text messages"
        },
        {
          "step": 2,
          "node": "Code Node",
          "example_code": "const msg = $input.first().json.message.text;\nconst match = msg.match(/(مصروف|expense)\\s+(\\d+\\.?\\d*)\\s+(.+)/i);\nif (match) {\n  return { json: { description: match[3].trim(), amount: parseFloat(match[2]), source: 'telegram' } };\n}\nreturn { json: { error: 'Could not parse' } };"
        },
        {
          "step": 3,
          "node": "HTTP Request",
          "config": {
            "method": "POST",
            "url": "{{base_url}}/api/external/expenses",
            "headers": { "Content-Type": "application/json", "X-API-Key": "={{api_key}}" }
          }
        },
        {
          "step": 4,
          "node": "Telegram Reply",
          "config": "✅ تم إدخال مصروف {{amount}} — {{description}}"
        }
      ]
    },

    "daily_alerts_check": {
      "description": "Daily smart alerts → Telegram notification",
      "flow": "Schedule Trigger (8 AM) → GET /alerts → Filter Critical → Telegram",
      "steps": [
        { "step": 1, "node": "Schedule Trigger", "config": "Daily at 8:00 AM" },
        { "step": 2, "node": "HTTP Request", "config": { "method": "GET", "url": "{{base_url}}/api/external/alerts" } },
        { "step": 3, "node": "IF Node", "config": "data.summary.critical_count > 0" },
        { "step": 4, "node": "Telegram", "config": "🚨 {{critical_count}} تنبيه حرج!\n{{alerts_list}}" }
      ]
    }
  },

  "curl_examples": {
    "verify_key": "curl -H 'X-API-Key: pyra_YOUR_KEY' https://workspace.pyramedia.cloud/api/external/status",
    "get_categories": "curl -H 'X-API-Key: pyra_YOUR_KEY' https://workspace.pyramedia.cloud/api/external/expenses/categories",
    "search_subscriptions": "curl -H 'X-API-Key: pyra_YOUR_KEY' 'https://workspace.pyramedia.cloud/api/external/subscriptions?search=eleven'",
    "create_subscription": "curl -X POST https://workspace.pyramedia.cloud/api/external/subscriptions -H 'Content-Type: application/json' -H 'X-API-Key: pyra_YOUR_KEY' -d '{\"name\": \"ElevenLabs\", \"provider\": \"ElevenLabs\", \"cost\": 5, \"currency\": \"USD\", \"billing_cycle\": \"monthly\", \"source\": \"curl\"}'",
    "create_expense_with_subscription": "curl -X POST https://workspace.pyramedia.cloud/api/external/expenses -H 'Content-Type: application/json' -H 'X-API-Key: pyra_YOUR_KEY' -d '{\"description\": \"ElevenLabs — تجديد شهري\", \"amount\": 5, \"currency\": \"USD\", \"category_id\": \"ec_SUBSCRIPTIONS_ID\", \"subscription_id\": \"sub_EXISTING_ID\", \"vendor\": \"ElevenLabs\", \"source\": \"curl\"}'",
    "create_expense_simple": "curl -X POST https://workspace.pyramedia.cloud/api/external/expenses -H 'Content-Type: application/json' -H 'X-API-Key: pyra_YOUR_KEY' -d '{\"description\": \"غداء عمل\", \"amount\": 250, \"category_id\": \"ec_FOOD_ID\", \"source\": \"curl\"}'",
    "list_expenses": "curl -H 'X-API-Key: pyra_YOUR_KEY' 'https://workspace.pyramedia.cloud/api/external/expenses?from=2026-01-01&to=2026-02-28'",
    "list_invoices": "curl -H 'X-API-Key: pyra_YOUR_KEY' 'https://workspace.pyramedia.cloud/api/external/invoices?status=sent'",
    "send_invoice": "curl -X POST -H 'X-API-Key: pyra_YOUR_KEY' https://workspace.pyramedia.cloud/api/external/invoices/inv_abc123/send",
    "get_alerts": "curl -H 'X-API-Key: pyra_YOUR_KEY' https://workspace.pyramedia.cloud/api/external/alerts"
  },

  "error_codes": {
    "401": "مفتاح API غير صالح أو مفقود — Invalid or missing API key",
    "403": "لا تملك الصلاحية المطلوبة — Missing required permission",
    "422": "بيانات غير صالحة — Validation error (check required fields)",
    "500": "خطأ في الخادم — Server error"
  },

  "available_permissions": [
    { "permission": "*", "description": "Full access to all endpoints" },
    { "permission": "expenses:create", "description": "Create expenses via POST /api/external/expenses" },
    { "permission": "expenses:read", "description": "List expenses + categories via GET /api/external/expenses[/categories]" },
    { "permission": "subscriptions:read", "description": "Search/list subscriptions via GET /api/external/subscriptions" },
    { "permission": "subscriptions:create", "description": "Create subscriptions via POST /api/external/subscriptions" },
    { "permission": "invoices:create", "description": "Create invoices via POST /api/external/invoices" },
    { "permission": "invoices:read", "description": "List invoices via GET /api/external/invoices" },
    { "permission": "invoices:send", "description": "Send draft invoices via POST /api/external/invoices/{id}/send" },
    { "permission": "alerts:read", "description": "Read finance alerts via GET /api/external/alerts" },
    { "permission": "payments:read", "description": "Read payment data (future endpoint)" }
  ],

  "webhook_events": [
    { "event": "expense_created", "description": "Fired when a new expense is created (internal or external)" },
    { "event": "invoice_created", "description": "Fired when a new invoice is created" },
    { "event": "invoice_sent", "description": "Fired when an invoice status changes to sent" },
    { "event": "invoice_paid", "description": "Fired when an invoice is fully paid" },
    { "event": "subscription_created", "description": "Fired when a new subscription is created via external API" }
  ]
}
